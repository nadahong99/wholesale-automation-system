# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./wholesale.db

# ── Naver API ─────────────────────────────────────────────────────────────────
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
NAVER_DATALAB_CLIENT_ID=your_naver_datalab_client_id
NAVER_DATALAB_CLIENT_SECRET=your_naver_datalab_client_secret

# ── Coupang API ───────────────────────────────────────────────────────────────
COUPANG_ACCESS_KEY=your_coupang_access_key
COUPANG_SECRET_KEY=your_coupang_secret_key
COUPANG_VENDOR_ID=your_coupang_vendor_id

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CEO_CHAT_ID=your_telegram_ceo_chat_id

# ── Google Cloud Storage ──────────────────────────────────────────────────────
GCS_BUCKET_NAME=wholesale-products
GCS_CREDENTIALS_PATH=credentials/gcs-key.json

# ── Google Sheets ─────────────────────────────────────────────────────────────
GOOGLE_SHEETS_CREDENTIALS_PATH=credentials/sheets-key.json
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key

# ── Celery / Redis ────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Application ───────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=False
SECRET_KEY=change-me-in-production

# ── Sourcing ──────────────────────────────────────────────────────────────────
DAILY_SOURCING_TARGET=500
GOLDEN_KEYWORD_THRESHOLD=10.0
MIN_MARGIN_PERCENT=20.0
INITIAL_DAILY_BUDGET=1000000

# ── Wholesaler credentials ────────────────────────────────────────────────────
DAEMAETOPIA_USERNAME=
DAEMAETOPIA_PASSWORD=
EASYMARKET_USERNAME=
EASYMARKET_PASSWORD=
DAEMAEPARTNER_USERNAME=
DAEMAEPARTNER_PASSWORD=
SINSANG_USERNAME=
SINSANG_PASSWORD=
MURRAYKOREA_USERNAME=
MURRAYKOREA_PASSWORD=
DALGOLMART_USERNAME=
DALGOLMART_PASSWORD=
