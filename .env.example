# Database
DATABASE_URL=sqlite:///./wholesale.db
POSTGRES_URL=postgresql://user:password@localhost:5432/wholesale

# Naver API
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
NAVER_DATALAB_KEY=your_datalab_key

# Coupang API
COUPANG_ACCESS_KEY=your_coupang_access_key
COUPANG_SECRET_KEY=your_coupang_secret_key
COUPANG_VENDOR_ID=your_vendor_id

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Google Cloud
GCS_BUCKET_NAME=your_gcs_bucket
GOOGLE_APPLICATION_CREDENTIALS=./service_account.json
GOOGLE_SHEETS_ID=your_sheets_id

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# App Settings
SECRET_KEY=your_secret_key_here
DEBUG=False
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# Business Logic
MIN_MARGIN_PERCENT=20
DAILY_BUDGET=500000
NAVER_FEE_RATE=0.055
COUPANG_FEE_RATE=0.108
SHIPPING_COST=3000
GOLDEN_KEYWORD_RATIO=10
CASH_WARNING_THRESHOLD=100000
